        "responses": {
          "values": [
            {
              "content": "=Generate a WhatsApp sales alert for the real estate sales manager.\n\n🆕 New site visit booked:\n- Name: {{ $('Parse & Format Output').item.json.display_name || 'Not provided' }}\n- Phone: {{ $('Parse & Format Output').item.json.customer_phone || $('Filter').item.json.contacts[0].wa_id }}\n- Property: {{ $('Parse & Format Output').item.json.properties_mentioned_string || 'Not specified' }}\n- Budget: {{ $('Parse & Format Output').item.json.budget || 'Not provided' }}\n- BHK: {{ $('Parse & Format Output').item.json.bhk_config || 'Not specified' }}\n- Visit Date: {{ $('Parse & Format Output').item.json.visit_date || 'Not set' }}\n- Visit Time: {{ $('Parse & Format Output').item.json.visit_time || 'Not set' }}\n- Visit Info: {{ $('Parse & Format Output').item.json.appointment_info }}\n- Booked At: {{ $now.setZone('Asia/Kolkata').toFormat('dd MMM yyyy, hh:mm a') }} IST\n\nClean WhatsApp format with emojis. Max 12 lines. End with follow-up action note for team."
            },
            {
              "role": "system",
              "content": "=You are a sales reporting assistant. Generate concise WhatsApp alert messages. Plain text only — no JSON, no markdown."
            }
          ]
        },
        "builtInTools": {},
        "options": {}
