    {
      "parameters": {
        "jsCode": "const item = $input.item;\n\nif (item.binary && item.binary.data) {\n  const url = String(item.json.image_urls || '');\n  let mimeType = 'image/jpeg';\n  let ext = 'jpeg';\n  if (url.toLowerCase().includes('.png')) { mimeType = 'image/png'; ext = 'png'; }\n  else if (url.toLowerCase().includes('.webp')) { mimeType = 'image/webp'; ext = 'webp'; }\n  item.binary.data.mimeType = mimeType;\n  item.binary.data.fileName = `property_${Date.now()}.${ext}`;\n  item.binary.data.fileExtension = ext;\n}\nreturn item;"
      },
