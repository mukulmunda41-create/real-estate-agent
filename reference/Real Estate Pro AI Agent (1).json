    {
      "parameters": {
        "jsCode": "// ============================================\n// PARSE & FORMAT — With Display Name Fix\n// ============================================\n\nlet agentOutput;\n\ntry {\n  const rawOutput = $json.output;\n\n  if (typeof rawOutput === 'object' && rawOutput !== null) {\n    agentOutput = rawOutput;\n  } else if (typeof rawOutput === 'string') {\n    let cleaned = rawOutput.trim();\n    cleaned = cleaned.replace(/^```json\\s*/i, '').replace(/\\s*```$/i, '');\n    cleaned = cleaned.replace(/^```\\s*/i, '').replace(/\\s*```$/i, '');\n    const jsonMatch = cleaned.match(/\\{[\\s\\S]*\\}/);\n    if (jsonMatch) cleaned = jsonMatch[0];\n    agentOutput = JSON.parse(cleaned);\n  } else {\n    throw new Error('Bad output: ' + typeof rawOutput);\n  }\n} catch (e) {\n  return [{\n    json: {\n      message: \"I'm here to help! Which property or area are you interested in?\",\n      has_image: false,\n      image_urls: [],\n      properties_mentioned: [],\n      properties_mentioned_string: '',\n      customer_name: '',\n      customer_phone: '',\n      display_name: '',\n      wa_display_name: '',\n      budget: '',\n      preferred_location: '',\n      bhk_config: '',\n      appointment_requested: false,\n      appointment_info: '',\n      calendar_event_link: '',\n      visit_date: '',\n      visit_time: '',\n      conversation_type: 'general_query',\n      conversation_complete: false,\n      last_interaction_timestamp: new Date().toISOString(),\n      _parse_error: true,\n      _error_detail: e.message\n    }\n  }];\n}\n\n// --- Display Name Logic ---\nconst waDisplayName = $('Filter').item.json.contacts[0]?.profile?.name || '';\nconst waId = $('Filter').item.json.contacts[0]?.wa_id || '';\nconst phoneFormatted = waId.startsWith('91')\n  ? '+91 ' + waId.slice(2)\n  : '+' + waId;\n\n// Priority: Agent collected name > WA Display Name > Phone\nagentOutput.display_name =\n  (agentOutput.customer_name && agentOutput.customer_name.trim() !== '')\n    ? agentOutput.customer_name.trim()\n    : (waDisplayName && waDisplayName.trim() !== '')\n      ? waDisplayName.trim()\n      : phoneFormatted;\n\nagentOutput.wa_display_name = waDisplayName || phoneFormatted;\n\n// --- Normalize Fields ---\n\n// properties_mentioned\nif (typeof agentOutput.properties_mentioned === 'string') {\n  agentOutput.properties_mentioned = agentOutput.properties_mentioned\n    ? [agentOutput.properties_mentioned] : [];\n}\nif (!Array.isArray(agentOutput.properties_mentioned)) {\n  agentOutput.properties_mentioned = [];\n}\nagentOutput.properties_mentioned_string = agentOutput.properties_mentioned.join(', ');\n\n// booleans\nagentOutput.has_image = agentOutput.has_image === true || agentOutput.has_image === 'true';\nagentOutput.appointment_requested = agentOutput.appointment_requested === true || agentOutput.appointment_requested === 'true';\nagentOutput.conversation_complete = agentOutput.conversation_complete === true || agentOutput.conversation_complete === 'true';\n\n// image_urls\nif (!Array.isArray(agentOutput.image_urls)) {\n  agentOutput.image_urls = agentOutput.image_urls\n    ? [String(agentOutput.image_urls)] : [];\n}\nagentOutput.image_urls = agentOutput.image_urls.filter(u => u && u.trim() !== '');\nif (agentOutput.image_urls.length === 0) agentOutput.has_image = false;\n\n// conversation_type\nconst validTypes = [\n  'property_inquiry', 'pricing_query',\n  'site_visit_booking', 'general_query', 'investment_inquiry'\n];\nif (!validTypes.includes(agentOutput.conversation_type)) {\n  agentOutput.conversation_type = 'general_query';\n}\n\n// string fields\nconst strFields = [\n  'message', 'customer_name', 'customer_phone',\n  'budget', 'preferred_location', 'bhk_config',\n  'appointment_info', 'calendar_event_link',\n  'visit_date', 'visit_time'\n];\nfor (const f of strFields) {\n  agentOutput[f] = agentOutput[f] != null\n    ? String(agentOutput[f]).trim() : '';\n}\n\nif (!agentOutput.message) agentOutput.message = 'How can I help you today?';\n\n// IST timestamp\nconst now = new Date();\nconst ist = new Date(now.getTime() + (5.5 * 60 * 60000));\nagentOutput.last_interaction_timestamp = ist.toISOString().replace('Z', '+05:30');\n\nreturn [{ json: agentOutput }];"
      },
