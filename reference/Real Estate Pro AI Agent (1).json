    {
      "parameters": {
        "jsCode": "const output = $json.output;\nlet alertText = '';\n\ntry {\n  if (typeof output === 'string') {\n    alertText = output.trim();\n  } else if (Array.isArray(output)) {\n    if (output[0]?.content?.[0]?.text) {\n      alertText = output[0].content[0].text.trim();\n    } else if (typeof output[0]?.content === 'string') {\n      alertText = output[0].content.trim();\n    } else if (typeof output[0] === 'string') {\n      alertText = output[0].trim();\n    }\n  } else if (typeof output === 'object' && output !== null) {\n    alertText = output.text || output.content || JSON.stringify(output);\n  }\n} catch(e) {\n  alertText = '🏠 New Site Visit booked. Please check CRM for details.';\n}\n\nif (!alertText) {\n  alertText = '🏠 New Site Visit booked. Please check CRM for details.';\n}\n\nreturn [{ json: { alert_text: alertText } }];"
      },
